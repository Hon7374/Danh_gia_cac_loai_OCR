# =========================
# OCR Full Demo Environment
# =========================

# Tesseract: Ä‘á»ƒ trá»‘ng Ä‘á»ƒ app tá»± dÃ² theo PATH/common Windows paths.
# Náº¿u Ä‘Ã£ cÃ i nhÆ°ng app chÆ°a nháº­n, Ä‘áº·t Ä‘Æ°á»ng dáº«n cá»¥ thá»ƒ:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
TESSERACT_LANG=vie+eng
# Optional. Leave empty to auto-use ./models/tessdata when present.
TESSERACT_TESSDATA_DIR=

# GLM-OCR / Z.ai layout parsing API
# Cháº¥p nháº­n GLM_OCR_API_KEY hoáº·c ZAI_API_KEY.
# Äá»ƒ trá»‘ng key thÃ¬ app tá»± dÃ¹ng GLM-OCR local miá»…n phÃ­ qua Hugging Face.
GLM_OCR_LOCAL=1
GLM_OCR_API_KEY=
ZAI_API_KEY=
GLM_OCR_ENDPOINT=https://api.z.ai/api/paas/v4/layout_parsing

# PaddleOCR-VL
# Náº¿u cÃ i PaddleOCR 3.x/PaddleOCR-VL, app sáº½ thá»­ import: from paddleocr import PaddleOCRVL.
# CÃ¡ch bá»n hÆ¡n: cáº¥u hÃ¬nh CLI command chÃ­nh thá»©c, vÃ­ dá»¥:
# PADDLEOCR_VL_CMD=paddleocr doc_parser -i "{input}" --device {device} --save_path "{output_dir}"
OCR_DEVICE=auto
TORCH_DEVICE=auto
PADDLE_DEVICE=auto
PADDLEOCR_VL_CMD=
PADDLEOCR_VL_DEVICE=auto
# Optional: transformers hoáº·c Ä‘á»ƒ trá»‘ng dÃ¹ng máº·c Ä‘á»‹nh PaddlePaddle.
PADDLEOCR_VL_ENGINE=

# LayoutLMv3 háº­u xá»­ lÃ½: cáº§n model token-classification Ä‘Ã£ fine-tune.
# Náº¿u Ä‘á»ƒ trá»‘ng, app fallback rule/regex Ä‘á»ƒ demo váº«n cháº¡y.
LAYOUTLMV3_MODEL_DIR=
LAYOUTLMV3_MODEL_NAME=welcomyou/layoutlmv3-vn-admin-kie
LAYOUTLMV3_PROCESSOR_NAME=microsoft/layoutlmv3-base
LAYOUTLMV3_MAX_WORDS=512

# Hiá»‡u nÄƒng local CPU
OCR_PDF_DPI=180
OCR_MAX_IMAGE_SIDE=2200
DOCUMENT_STORAGE_DIR=D:\ocr_workspace\storage
OCR_OPENCV_WORKERS=4
OCR_TESSERACT_WORKERS=4
OCR_GPU_WORKERS=1
PADDLE_VIETOCR_REFINE=0
VIETOCR_CONFIG_PATH=
VIETOCR_WEIGHTS_PATH=
VIETOCR_BATCH_SIZE=48
